# API container — no JDK needed (PySpark not used here)
FROM python:3.11-slim

WORKDIR /app

COPY api-requirements.txt .
RUN pip install --no-cache-dir -r api-requirements.txt

COPY . .

RUN mkdir -p data/raw data/processed output/dossiers

EXPOSE 8000

# Single worker: stdout capture for SSE is not multiprocess-safe.
# Concurrency comes from asyncio + the scan lock in api/stream.py.
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
